    "dev:frontend": "cd artifacts/financial-sandbox && npx vite --config vite.config.ts --host 0.0.0.0"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
