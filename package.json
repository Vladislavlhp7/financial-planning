{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/financial-sandbox",
    "artifacts/mockup-sandbox",
    "lib/api-client-react",
    "lib/api-spec",
    "lib/api-zod",
    "scripts"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
